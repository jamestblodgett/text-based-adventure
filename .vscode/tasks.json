{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "javac: build",
      "type": "shell",
      "command": "javac",
      "args": [
        "-d",
        "out",
        "${workspaceFolder}\\src\\**\\*.java"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$java"
      ]
    },
    {
      "label": "java: run",
      "type": "shell",
      "dependsOn": "javac: build",
      "command": "java",
      "args": [
        "-cp",
        "out",
        "Main"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}